# NeuroEva Configuration
# Получите BOT_TOKEN у @BotFather в Telegram
BOT_TOKEN=ваш_токен_от_BotFather
# Ваш Telegram ID (узнайте у @userinfobot)
CREATOR_ID=ваш_telegram_id
# Использовать Colab для генерации изображений (true/false)
USE_COLAB=false
# URL вашего Colab-сервера (если USE_COLAB=true)
COLAB_URL=https://your-ngrok.ngrok-free.dev
# Токен ngrok (необязательно, если используется авто-поднятие)
NGROK_TOKEN=ваш_ngrok_токен_если_нужен
